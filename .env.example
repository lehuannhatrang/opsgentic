# vLLM (OpenAI-compatible endpoint). Leave LLM_BASE_URL empty -> agents use the canned fallback.
LLM_BASE_URL=http://localhost:8000/v1
LLM_API_KEY=
LLM_MODEL=local-model
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=4096

# MCP (single gateway for all cluster tools, read-only). Enable in-cluster.
MCP_ENABLED=false
MCP_CONFIG_PATH=mcp-config/servers.yaml
MCP_RECURSION_LIMIT=25
# Agent skills (editable markdown prompts) auto-resolve: /app/agent-skills in-cluster,
# deploy/manifests/agent-skills for local repo-root runs. Uncomment to override the path.
# SKILLS_PATH=deploy/manifests/agent-skills
# URLs of the deployed MCP servers (referenced by mcp-config/servers.yaml).
K8S_MCP_URL=http://kubernetes-mcp.opsgentic.svc:8080/mcp
GITHUB_MCP_URL=http://github-mcp.opsgentic.svc:8082/mcp
# Optional: github-mcp read token. Defaults to GITHUB_TOKEN if left empty — set a separate
# value only for a least-privilege read-only token.
GITHUB_MCP_TOKEN=

# GitOps provider registry + Git credentials.
GIT_CONFIG_PATH=config/gitops.yaml
# Default: a fine-grained PAT on the target repo (Contents: RW, Pull requests: RW).
GITHUB_TOKEN=
# Optional (production): a GitHub App instead of the PAT — short-lived installation tokens.
# Leave GITHUB_TOKEN empty if you use the App.
# GITHUB_APP_ID=
# GITHUB_APP_INSTALLATION_ID=
# GITHUB_APP_PRIVATE_KEY_PATH=
# GITHUB_APP_PRIVATE_KEY=        # alternative: inline PEM (use \n for newlines)
# Other providers (only if you target Gitea/GitLab repos; see config/gitops.yaml):
# GITEA_TOKEN=
# GITLAB_TOKEN=

# Durable checkpointing (Postgres). Empty -> in-memory (dev, single process).
DATABASE_URL=
DB_POOL_MAX_SIZE=10

# App
LOG_LEVEL=INFO
MAX_RCA_ATTEMPTS=2
# Auto-approve: true -> passing validation opens the PR automatically (review/merge is the gate).
# false -> pause for human approve via /runs/{id}/approve or /ui/{id}.
AUTO_APPROVE=false

# vLLM (OpenAI-compatible endpoint). Leave LLM_BASE_URL empty -> agents use the canned fallback.
LLM_BASE_URL=http://localhost:8000/v1
LLM_API_KEY=
LLM_MODEL=local-model
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=4096

# MCP (read-only context enrichment). Enable in-cluster; leave false for local dev.
MCP_ENABLED=false
MCP_CONFIG_PATH=mcp-config/servers.yaml
MCP_RECURSION_LIMIT=12

# GitOps provider registry + per-provider bot tokens (one dedicated account each).
GIT_CONFIG_PATH=config/gitops.yaml
GITHUB_TOKEN=
GITEA_TOKEN=
GITLAB_TOKEN=
# Legacy single-provider fallback (used for hosts not in the registry):
GIT_PROVIDER=github
GIT_TOKEN=
GIT_BASE_URL=

# Durable checkpointing (Postgres). Empty -> in-memory (dev, single process).
DATABASE_URL=
DB_POOL_MAX_SIZE=10

# App
LOG_LEVEL=INFO
MAX_RCA_ATTEMPTS=2

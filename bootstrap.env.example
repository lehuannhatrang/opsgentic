# Copy to bootstrap.env and fill in, then run ./bootstrap.sh. (bootstrap.env is gitignored.)

# --- vLLM (OpenAI-compatible endpoint) ---
LLM_BASE_URL=http://your-vllm:8000/v1
LLM_API_KEY=
LLM_MODEL=

# --- GitHub App (create one, install it on your demo-workload fork) ---
GITHUB_APP_ID=
GITHUB_APP_INSTALLATION_ID=
GITHUB_APP_PRIVATE_KEY_PATH=
# Optional read-only PAT for github-mcp (the App installation token is used when configured):
GITHUB_MCP_TOKEN=

# --- App image ---
IMAGE=docker.io/lehuannhatrang/opsgentic
IMAGE_TAG=dev-1.0

# --- Postgres (leave blank to auto-generate a password) ---
POSTGRES_PASSWORD=

# --- Behavior ---
AUTO_APPROVE=true

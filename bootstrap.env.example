# Copy to bootstrap.env and fill in, then run ./bootstrap.sh. (bootstrap.env is gitignored.)

# --- vLLM (OpenAI-compatible endpoint) ---
LLM_BASE_URL=http://your-vllm:8000/v1
LLM_API_KEY=
LLM_MODEL=

# --- GitHub auth — pick ONE ---
# Default (easy): a fine-grained PAT on your demo-workload fork
#   (Contents: Read & write, Pull requests: Read & write). Covers PRs + repo reads.
GITHUB_TOKEN=
# Token github-mcp uses to read the repo; leave blank to reuse GITHUB_TOKEN.
GITHUB_MCP_TOKEN=
#
# Optional (production): a GitHub App instead of a PAT — short-lived installation tokens.
# Leave these blank to use the PAT above.
GITHUB_APP_ID=
GITHUB_APP_INSTALLATION_ID=
GITHUB_APP_PRIVATE_KEY_PATH=

# --- App image ---
IMAGE=docker.io/lehuannhatrang/opsgentic
IMAGE_TAG=dev-1.0

# --- Postgres (leave blank to auto-generate a password) ---
POSTGRES_PASSWORD=

# --- Behavior ---
AUTO_APPROVE=true
